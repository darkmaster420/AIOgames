# Production Environment Variables (Default)
# Copy this to .env and fill in your production values

# 🌐 Your Domain (CHANGE THIS!)
NEXTAUTH_URL=https://yourdomain.com

# 🔐 Authentication Secret (GENERATE A STRONG SECRET!)
NEXTAUTH_SECRET=your-super-secret-nextauth-secret-change-this-in-production

# 📊 MongoDB Atlas Connection (RECOMMENDED FOR PRODUCTION)
# Get this from your MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aiogames?retryWrites=true&w=majority

# � Owner User (Created at startup - Full admin access + user management)
OWNER_EMAIL=owner@yourdomain.com
OWNER_PASSWORD=change-this-secure-password
OWNER_NAME=Owner

# �👤 Admin User (Will be created automatically - Can manage games and ban users)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-secure-password
ADMIN_NAME=Admin User

# 📱 Telegram Bot (Shared bot for all users)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
# Users only need to provide their Telegram username or user ID to receive notifications

# 🎮 Game API
GAME_API_URL=https://gameapi.a7a8524.workers.dev

# 📦 Environment use development .env if youre developing!!
NODE_ENV=production

# 🧾 Logging (production defaults)
# Set to 'error' to only log errors, 'warn' to include warnings, 'info' for info, 'debug' for verbose
LOG_LEVEL=error
ENABLE_DEBUG_LOGS=false

# 🔧 External APIs
# Steam API (now integrated - these are optional overrides)
# Defaults to /api/steam in production, http://localhost:3002/api/steam in development
# Only set these if you need to use a different endpoint
# NEXT_PUBLIC_STEAM_API_BASE=/api/steam
# STEAM_API_BASE=/api/steam
# NEXT_PUBLIC_APP_URL=http://localhost:3002  # For Node.js scripts/tests

# 🎮 IGDB (Internet Game Database) - For unreleased games
# Get these from https://dev.twitch.tv/console (create an app and get Client ID and Secret)
# Used to find unreleased/upcoming games when they're not available on piracy sites yet
IGDB_CLIENT_ID=your-twitch-client-id
IGDB_CLIENT_SECRET=your-twitch-client-secret

# 🎮 RAWG.io (Fallback game images when IGDB fails - 20k req/month free)
# Get a key from https://rawg.io/apidocs
RAWG_API_KEY=your-rawg-api-key