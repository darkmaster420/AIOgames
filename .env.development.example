# Development Environment Variables
# Copy this to .env for local development with containers

# 🌐 Local development URL
NEXTAUTH_URL=http://localhost:3000

# 🔐 Development secret (change for production!)
NEXTAUTH_SECRET=development-secret-key-change-for-production

# 📱 Telegram Bot will run locally with polling
TELEGRAM_BOT_TOKEN=12345678:bot-token-for-development-only

# 📊 Local MongoDB Connection (for development containers)
MONGODB_URI=mongodb://aiogames:aiogames123@mongodb:27017/aiogames

# 👤 Admin User (Development)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin User

# 🛡️ FlareSolverr (Cloudflare bypass for skidrow/steamrip)
# FLARESOLVERR_URL=http://localhost:8191/v1

# 📦 Environment
NODE_ENV=development

# 🎮 IGDB (Internet Game Database) - For unreleased games
# Get these from https://dev.twitch.tv/console (create an app and get Client ID and Secret)
# Used to find unreleased/upcoming games when they're not available on piracy sites yet
IGDB_CLIENT_ID=your-twitch-client-id
IGDB_CLIENT_SECRET=your-twitch-client-secret